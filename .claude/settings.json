{
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Edit(/.claude/skills/**)",
      "mcp__google-drive__search_files",
      "mcp__google-drive__list_files",
      "Edit(/.claude/skills/day-open/**)",
      "mcp__google-drive__create_folder",
      "mcp__google-drive__get_drive_info",
      "mcp__google-drive__list_shared_drives",
      "mcp__railway__list-projects",
      "mcp__railway__list-services",
      "mcp__railway__list-variables",
      "mcp__ext-linear__search_issues"
    ],
    "additionalDirectories": []
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/run-claude-hook.sh wp-gate-reminder.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/run-claude-hook.sh close-gate-reminder.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/run-claude-hook.sh extensions-gate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/run-claude-hook.sh protocol-artifact-validate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/run-claude-hook.sh protocol-completion-reminder.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/run-claude-hook.sh protocol-stop-gate.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/run-claude-hook.sh precompact-checkpoint.sh"
          }
        ]
      }
    ]
  }
}
